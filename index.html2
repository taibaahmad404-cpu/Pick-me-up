```

  </div>

  <!-- RSVP -->

  <div class="rsvp-card">
    <div id="rsvp-form">
      <div style="font-size:40px;margin-bottom:0.6rem;">🎟️</div>
      <h2>Are you coming? 🥹</h2>
      <p>Drop your name and let Diksha know you'll be there to make her day extra special!</p>
      <div class="input-wrap">
        <input type="text" id="guest-name" placeholder="Your name 🌸" maxlength="40"/>
      </div>
      <div class="btn-row">
        <button class="btn btn-yes" onclick="rsvpYes()">Absolutely YES! 🎉</button>
        <button class="btn btn-no" id="no-btn" onclick="noEscape()">Maybe later 😅</button>
      </div>
      <p id="name-warn" style="font-size:12px;color:#e06fa0;margin-top:10px;display:none;">Psst — enter your name first! 🌸</p>
    </div>
    <div class="rsvp-success" id="rsvp-success">
      <div class="big-emoji">🎊</div>
      <h3 id="success-msg">Yaaaay! See you there!</h3>
      <p id="success-sub">Diksha is SO excited you're coming. Don't be late! 🎀</p>
    </div>
  </div>

  <div class="footer">
    Made with <span>♥</span> for Diksha's special day 🎂
  </div>

</div>

<script>
  // ── Floating dots ──
  const bg = document.getElementById('bg');
  const colors = ['#f9a8c9','#ffd6b0','#b5e8d5','#d4b8f0','#ffe58a','#fde8f1'];
  for (let i = 0; i < 28; i++) {
    const d = document.createElement('div');
    d.className = 'dot';
    const size = 12 + Math.random() * 28;
    d.style.cssText = `
      width:${size}px; height:${size}px;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      left:${Math.random()*100}%;
      animation-duration:${10+Math.random()*18}s;
      animation-delay:${Math.random()*12}s;
    `;
    bg.appendChild(d);
  }

  // ── No button escape ──
  const noTexts = [
    "Nahi nahi, soch lo! 🤭",
    "Diksha will cry 😢",
    "It's her BIRTHDAY bestie 🎂",
    "Wrong button! Try again 🙈",
    "The universe says YES 🌸",
    "Your heart says come 💕",
    "Abhi bhi time hai! 😤",
    "PLEASEEE 🥺👉👈",
    "Ok fine... just kidding SAY YES",
    "You HAVE to come!! 🎉"
  ];
  let noCount = 0;
  function noEscape() {
    const btn = document.getElementById('no-btn');
    btn.textContent = noTexts[noCount % noTexts.length];
    noCount++;
    btn.style.background = '#fde8f1';
    btn.style.color = '#c45a8a';
    // wiggle animation
    btn.style.transform = 'scale(1.05) rotate(-2deg)';
    setTimeout(() => btn.style.transform = '', 300);
  }

  // ── RSVP Yes ──
  function rsvpYes() {
    const name = document.getElementById('guest-name').value.trim();
    if (!name) {
      document.getElementById('name-warn').style.display = 'block';
      return;
    }
    document.getElementById('rsvp-form').style.display = 'none';
    const success = document.getElementById('rsvp-success');
    success.style.display = 'block';
    document.getElementById('success-msg').textContent = `Yaaaay, ${name}! See you there! 🎊`;
    // burst confetti effect
    burstConfetti();
  }

  // ── Mini confetti burst ──
  function burstConfetti() {
    const colors2 = ['#f9a8c9','#ffd6b0','#b5e8d5','#d4b8f0','#ffe58a'];
    for (let i = 0; i < 18; i++) {
      const c = document.createElement('div');
      c.style.cssText = `
        position:fixed; z-index:999;
        width:${8+Math.random()*8}px; height:${8+Math.random()*8}px;
        background:${colors2[Math.floor(Math.random()*colors2.length)]};
        border-radius:${Math.random()>0.5?'50%':'3px'};
        left:${40+Math.random()*20}%; top:60%;
        pointer-events:none;
        transition: transform 1.2s ease, opacity 1.2s ease;
        opacity:1;
      `;
      document.body.appendChild(c);
      requestAnimationFrame(() => {
        c.style.transform = `translate(${-80+Math.random()*160}px, ${-180-Math.random()*120}px) rotate(${Math.random()*360}deg)`;
        c.style.opacity = '0';
      });
      setTimeout(() => c.remove(), 1400);
    }
  }
</script>

</body>
</html>
